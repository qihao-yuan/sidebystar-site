<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS site config for the Next.js production server (next start) running locally.

  Architecture:
    Browser  ->  IIS  (this site, port 80/443)  ->  ARR rewrite  ->  http://127.0.0.1:3000  (next start)

  Why this file is needed:

  1. requestFiltering allowDoubleEscaping="true"
     Next.js 14 emits client chunks under /_next/static/chunks/app/[locale]/page-*.js.
     The square brackets are URL-encoded as %5B/%5D in the HTML <script> tag.
     IIS Request Filtering rejects %5B/%5D by default with HTTP 400.

  2. URL Rewrite -> http://127.0.0.1:3000
     Forwards every request to the local Node process running `next start`.

  3. X-Forwarded-* headers
     Without these, next-intl and other libs see Host = 127.0.0.1:3000 and
     emit hreflang / canonical links pointing at localhost.

  4. Compression
     Next.js does NOT compress responses in production (it relies on the front
     proxy to do it). Without IIS dynamic compression enabled, every page ships
     ~30-160 KB of plain text. Turning on gzip/dynamic compression cuts the
     payload by 4-6x and removes most of the perceived "stale" feeling.
     The Web-Dyn-Compression Windows feature must also be installed:
       Install-WindowsFeature Web-Dyn-Compression

  5. SSL settings
     access sslFlags="Ssl" forces HTTPS but disables client certificate
     negotiation. Without this, IIS may renegotiate TLS on the first request,
     adding 1-20s of latency on cold connections.

  Deploy:
    Copy this file to the IIS site root (the same folder configured as the
    site's Physical Path in IIS Manager). IIS reloads it automatically;
    no app pool restart needed for these changes.
-->
<configuration>
  <system.webServer>

    <security>
      <access sslFlags="Ssl" />
      <requestFiltering allowDoubleEscaping="true" />
    </security>

    <rewrite>
      <rules>
        <rule name="ReverseProxyToNode" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:3000/{R:1}" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_HOST" value="{HTTP_HOST}" />
            <set name="HTTP_X_FORWARDED_PROTO" value="https" />
            <set name="HTTP_X_FORWARDED_FOR" value="{REMOTE_ADDR}" />
            <set name="HTTP_X_REAL_IP" value="{REMOTE_ADDR}" />
          </serverVariables>
        </rule>
      </rules>
    </rewrite>

    <urlCompression doStaticCompression="true" doDynamicCompression="true" />

    <httpCompression directory="%SystemDrive%\inetpub\temp\IIS Temporary Compressed Files">
      <scheme name="gzip" dll="%Windir%\system32\inetsrv\gzip.dll" staticCompressionLevel="9" dynamicCompressionLevel="4" />
      <dynamicTypes>
        <add mimeType="text/*" enabled="true" />
        <add mimeType="application/javascript" enabled="true" />
        <add mimeType="application/json" enabled="true" />
        <add mimeType="application/xml" enabled="true" />
        <add mimeType="application/rss+xml" enabled="true" />
        <add mimeType="image/svg+xml" enabled="true" />
        <add mimeType="*/*" enabled="false" />
      </dynamicTypes>
      <staticTypes>
        <add mimeType="text/*" enabled="true" />
        <add mimeType="application/javascript" enabled="true" />
        <add mimeType="application/json" enabled="true" />
        <add mimeType="image/svg+xml" enabled="true" />
        <add mimeType="font/*" enabled="true" />
        <add mimeType="*/*" enabled="false" />
      </staticTypes>
    </httpCompression>

    <httpProtocol>
      <customHeaders>
        <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
      </customHeaders>
    </httpProtocol>

    <staticContent>
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" />
      <remove fileExtension=".webp" />
      <mimeMap fileExtension=".webp" mimeType="image/webp" />
      <remove fileExtension=".avif" />
      <mimeMap fileExtension=".avif" mimeType="image/avif" />
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
    </staticContent>

  </system.webServer>
</configuration>
