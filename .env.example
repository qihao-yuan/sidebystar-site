# Copy this file to `.env.local` (development) or `.env.production.local` (cloud host)
# and fill in real values. `.env*` files are .gitignore'd - they must NEVER be committed.
#
# On the Windows production host:
#   copy .env.example .env.production.local
#   notepad .env.production.local     # fill in real values
#   .\deploy.ps1                      # or: pm2 restart sidebystar --update-env

# -----------------------------------------------------------------------------
# SMTP outbound - used by POST /api/contact to deliver form submissions as email.
# -----------------------------------------------------------------------------

# 阿里企业邮箱 (current production default):
#   SMTP_HOST=smtp.qiye.aliyun.com      # 新版企业邮箱
#   SMTP_HOST=smtp.mxhichina.com        # 旧版 / 免费域名邮箱(登录邮箱 Web 端 -> 设置 -> POP3/SMTP/IMAP 里会写具体地址)
#   SMTP_PORT=465
#   SMTP_SECURE=true
#
# 腾讯企业邮箱(免费版):
#   SMTP_HOST=smtp.exmail.qq.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
#
# 网易企业邮箱:
#   SMTP_HOST=smtp.qiye.163.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
SMTP_HOST=smtp.qiye.aliyun.com
SMTP_PORT=465
SMTP_SECURE=true

# Sending account. The user is the full mailbox address.
# For 阿里企业邮箱:
#   1. 登录邮箱 Web 端 -> 设置 -> POP3/SMTP/IMAP -> 开启 SMTP 服务
#   2. 同页面的"安全设置" -> 客户端独立密码 -> 开启并生成一个
#   3. SMTP_PASS 填这个"独立密码",不要用登录密码
SMTP_USER=no-reply@sidebystar.com
SMTP_PASS=replace-with-client-specific-password

# Envelope + display. MAIL_FROM must belong to the same domain as SMTP_USER
# or providers will reject / quarantine the message.
MAIL_FROM="SidebyStar Website <no-reply@sidebystar.com>"
MAIL_TO=contact@sidebystar.com
