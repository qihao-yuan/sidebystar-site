<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS reverse proxy -> Next.js (pm2 on 127.0.0.1:3000).
  Place this file as the root web.config of the IIS site that owns port 80/443.

  Prerequisites on the server (install once):
    1. IIS URL Rewrite       https://www.iis.net/downloads/microsoft/url-rewrite
    2. Application Request Routing (ARR) https://www.iis.net/downloads/microsoft/application-request-routing
    3. In IIS Manager -> server node -> Application Request Routing Cache ->
       Server Proxy Settings -> Enable proxy = ON -> Apply.
-->
<configuration>
  <system.webServer>

    <rewrite>
      <rules>
        <rule name="ReverseProxyToNextJS" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:3000/{R:1}" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_PROTO" value="{CACHE_URL:0:5}" />
            <set name="HTTP_X_FORWARDED_HOST"  value="{HTTP_HOST}" />
            <set name="HTTP_X_FORWARDED_FOR"   value="{REMOTE_ADDR}" />
          </serverVariables>
        </rule>
      </rules>
    </rewrite>

    <!-- Let Next.js render its own 404 / 500 pages instead of IIS default errors. -->
    <httpErrors existingResponse="PassThrough" />

    <!--
      NOTE: global <proxy> settings live in applicationHost.config at the server level
      (Application Request Routing Cache -> Server Proxy Settings). Do NOT put a site-level
      <proxy> element here; that section is locked by default and will 500 the whole site.

      Also make sure these server variables are whitelisted at server level, otherwise
      URL Rewrite refuses to set them and returns "URL Rewrite Module Error" 500:
        HTTP_X_FORWARDED_PROTO
        HTTP_X_FORWARDED_HOST
        HTTP_X_FORWARDED_FOR
      Add via PowerShell on the server:
        Add-WebConfigurationProperty -pspath 'MACHINE/WEBROOT/APPHOST' `
          -filter "system.webServer/rewrite/allowedServerVariables" `
          -name "." -value @{name='HTTP_X_FORWARDED_PROTO'}
    -->

  </system.webServer>
</configuration>
